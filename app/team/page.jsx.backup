// ═══════════════════════════════════════════
// MEMBER CARD
// ═══════════════════════════════════════════

function MemberCard({
  member,
  index,
  activeIndex,
  totalCards,
  onSelect,
  isMobile,
}) {
  const offset = index - activeIndex;
  const abs = Math.abs(offset);
  const active = offset === 0;
  const w = isMobile ? 140 : 200;
  const h = isMobile ? 200 : 280;
  const gap = isMobile ? 110 : 180;
  const maxV = isMobile ? 1.5 : 2.5;

  return (
    <div
      className="absolute left-1/2 top-1/2"
      style={{
        width: w,
        height: h,
        transform: `translate(-50%,-50%) translateX(${offset * gap}px) translateZ(${active ? (isMobile ? 50 : 80) : -(50 * abs)
          }px) rotateY(${offset * (isMobile ? -18 : -22)}deg) scale(${active
            ? isMobile
              ? 1.08
              : 1.12
            : Math.max(0.55, 1 - abs * 0.2)
          })`,
        opacity: abs > maxV ? 0 : active ? 1 : 0.4,
        zIndex: totalCards + 10 - abs,
        filter: active ? "none" : `blur(${Math.min(abs * 2, 5)}px)`,
        transition: "all 0.45s cubic-bezier(0.22,1,0.36,1)",
        willChange: "transform,opacity",
        pointerEvents: abs > maxV ? "none" : "auto",
      }}
      onClick={() => onSelect(index)}
      role="button"
      tabIndex={active ? 0 : -1}
      aria-label={`${member.name}, ${member.role}`}
    >
      <div
        className={`relative h-full w-full overflow-hidden rounded-xl border transition-shadow duration-500 ${active
          ? "border-white/20 shadow-[0_0_30px_rgba(255,255,255,0.08)]"
          : "border-white/[0.04]"
          }`}
      >
        <Image
          src={member.photo}
          alt={member.name}
          fill
          className="object-cover object-top"
          sizes={`${w}px`}
          priority={abs <= 1}
          quality={75}
        />
        <div className="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent" />
        {active && (
          <div className="absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-white/40 to-transparent" />
        )}
        <div
          className="absolute bottom-0 left-0 right-0 p-3 text-center"
          style={{
            transform: active ? "translateY(0)" : "translateY(8px)",
            opacity: active ? 1 : 0,
            transition: "all 0.4s ease",
          }}
        >
          <h3
            className={`font-bold leading-snug text-white ${isMobile ? "text-[11px]" : "text-sm"
              }`}
          >
            {member.name}
          </h3>
          <p
            className={`mt-0.5 font-medium uppercase tracking-wider text-white/50 ${isMobile ? "text-[8px]" : "text-[10px]"
              }`}
          >
            {member.role}
          </p>
          {isMobile && (
            <p className="mt-1 text-[7px] text-white/20">tap to view</p>
          )}
        </div>
      </div>
    </div>
  );
}

// ═══════════════════════════════════════════
// MEMBER MODAL
// ═══════════════════════════════════════════

function MemberModal({ member, isOpen, onClose }) {
  const overlayRef = useRef(null);
  const [mobile, setMobile] = useState(false);

  useEffect(() => {
    const c = () => setMobile(window.innerWidth < 768);
    c();
    window.addEventListener("resize", c);
    return () => window.removeEventListener("resize", c);
  }, []);

  const onKey = useCallback(
    (e) => {
      if (e.key === "Escape") onClose();
    },
    [onClose]
  );

  useEffect(() => {
    if (isOpen) {
      document.addEventListener("keydown", onKey);
      document.body.style.overflow = "hidden";
    }
    return () => {
      document.removeEventListener("keydown", onKey);
      document.body.style.overflow = "";
    };
  }, [isOpen, onKey]);

  if (!isOpen || !member) return null;

  const socials = [
    {
      key: "linkedin",
      url: member.linkedin,
      icon: FaLinkedinIn,
      label: "LinkedIn",
      hc: "hover:border-blue-500/30 hover:bg-blue-500/10 hover:text-blue-400",
    },
    {
      key: "gmail",
      url: member.gmail ? `mailto:${member.gmail}` : "",
      icon: FaEnvelope,
      label: "Email",
      hc: "hover:border-red-500/30 hover:bg-red-500/10 hover:text-red-400",
    },
    {
      key: "instagram",
      url: member.instagram,
      icon: FaInstagram,
      label: "Instagram",
      hc: "hover:border-pink-500/30 hover:bg-pink-500/10 hover:text-pink-400",
    },
  ].filter((s) => s.url);

  return (
    <div
      ref={overlayRef}
      className="fixed inset-0 z-[100] flex items-end md:items-center justify-center"
      onClick={(e) => {
        if (e.target === overlayRef.current) onClose();
      }}
      role="dialog"
      aria-modal="true"
    >
      <div
        className="absolute inset-0 bg-black/60 backdrop-blur-sm"
        style={{ animation: "fadeIn 0.25s ease forwards" }}
      />
      <div
        className={`relative z-10 w-full ${mobile ? "max-h-[88vh]" : "max-w-[420px] mx-4"
          }`}
        style={{
          animation:
            "modalSlideUp 0.35s cubic-bezier(0.16,1,0.3,1) forwards",
        }}
      >
        <div
          className={`overflow-hidden border border-white/[0.08] bg-[#0f0f25]/95 backdrop-blur-xl shadow-2xl ${mobile ? "rounded-t-2xl" : "rounded-2xl"
            }`}
        >
          {mobile && (
            <div className="flex justify-center pt-2.5 pb-1">
              <div className="h-1 w-9 rounded-full bg-white/15" />
            </div>
          )}
          <button
            onClick={onClose}
            className="absolute right-3 top-3 z-20 flex h-9 w-9 items-center justify-center rounded-full bg-black/50 text-white/50 hover:text-white active:scale-95"
            aria-label="Close"
          >
            <FaXmark size={15} />
          </button>

          <div className={`relative w-full ${mobile ? "h-56" : "h-72"}`}>
            <Image
              src={member.photo}
              alt={member.name}
              fill
              className="object-cover object-top"
              sizes={mobile ? "100vw" : "420px"}
              priority
              quality={80}
            />
            <div className="absolute inset-0 bg-gradient-to-t from-[#0f0f25] via-transparent to-transparent" />
          </div>

          <div
            className={`-mt-4 relative z-10 text-center ${mobile ? "px-5 pb-7" : "px-7 pb-7"
              }`}
          >
            <h2
              className={`font-bold text-white ${mobile ? "text-lg" : "text-xl"
                }`}
            >
              {member.name}
            </h2>
            <div className="mt-2 inline-flex items-center gap-1.5 rounded-full border border-white/[0.06] bg-white/[0.03] px-3.5 py-1">
              <span className="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse" />
              <span className="text-[10px] font-medium uppercase tracking-[0.15em] text-white/50">
                {member.role}
              </span>
            </div>
            <div className="mx-auto my-5 h-px w-12 bg-white/[0.08]" />
            {socials.length > 0 && (
              <div className="flex items-center justify-center gap-3">
                {socials.map((s) => (
                  <a
                    key={s.key}
                    href={s.url}
                    target={s.key === "gmail" ? undefined : "_blank"}
                    rel={
                      s.key === "gmail" ? undefined : "noopener noreferrer"
                    }
                    className="flex flex-col items-center gap-1.5 group"
                    aria-label={`${member.name} ${s.label}`}
                  >
                    <div
                      className={`flex h-11 w-11 items-center justify-center rounded-xl border border-white/[0.05] bg-white/[0.03] text-white/35 transition-all active:scale-95 ${s.hc}`}
                    >
                      <s.icon size={17} />
                    </div>
                    <span className="text-[8px] font-medium uppercase tracking-wider text-white/20">
                      {s.label}
                    </span>
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}

// ═══════════════════════════════════════════
// DEPARTMENT CAROUSEL
// ═══════════════════════════════════════════

function DepartmentCarousel({
  department,
  onMemberClick,
  playGearClick,
  playEngraveThud,
  particleCanvasRef,
}) {
  const [activeIndex, setActiveIndex] = useState(0);
  const [isMobile, setIsMobile] = useState(false);
  const containerRef = useRef(null);
  const s = useRef({
    isDragging: false,
    startX: 0,
    dragDist: 0,
    lastTickDist: 0,
    lastIndex: 0,
    velocity: 0,
    lastMoveX: 0,
    lastMoveTime: 0,
    startTime: 0,
  });

  const { members } = department;

  useEffect(() => {
    const c = () => setIsMobile(window.innerWidth < 768);
    c();
    window.addEventListener("resize", c);
    return () => window.removeEventListener("resize", c);
  }, []);

  const snapTo = useCallback(
    (idx) => {
      const clamped = Math.max(0, Math.min(members.length - 1, idx));
      const st = s.current;
      if (clamped !== st.lastIndex) {
        st.lastIndex = clamped;
        setActiveIndex(clamped);
        playEngraveThud();
        if (containerRef.current && particleCanvasRef?.current) {
          const r = containerRef.current.getBoundingClientRect();
          particleCanvasRef.current.burst(
            r.left + r.width / 2,
            r.top + r.height / 2
          );
        }
        if (typeof navigator !== "undefined" && navigator.vibrate)
          navigator.vibrate(25);
      }
    },
    [members.length, playEngraveThud, particleCanvasRef]
  );

  const onDS = useCallback((cx) => {
    const st = s.current;
    st.isDragging = true;
    st.startX = cx;
    st.dragDist = 0;
    st.lastTickDist = 0;
    st.velocity = 0;
    st.lastMoveX = cx;
    st.lastMoveTime = Date.now();
    st.startTime = Date.now();
  }, []);

  const onDM = useCallback(
    (cx) => {
      const st = s.current;
      if (!st.isDragging) return;
      st.dragDist = st.startX - cx;
      const now = Date.now();
      const dt = now - st.lastMoveTime;
      if (dt > 0) st.velocity = (st.lastMoveX - cx) / dt;
      st.lastMoveX = cx;
      st.lastMoveTime = now;
      const tick = isMobile ? 40 : 55;
      const abs = Math.abs(st.dragDist);
      if (abs - st.lastTickDist >= tick) {
        playGearClick();
        st.lastTickDist = abs;
        if (typeof navigator !== "undefined" && navigator.vibrate)
          navigator.vibrate(8);
      }
    },
    [playGearClick, isMobile]
  );

  const onDE = useCallback(() => {
    const st = s.current;
    if (!st.isDragging) return;
    st.isDragging = false;
    const elapsed = Date.now() - st.startTime;
    if (elapsed < 250 && Math.abs(st.dragDist) < 12) return;
    const threshold = isMobile ? 25 : 40;
    if (Math.abs(st.dragDist) > threshold || Math.abs(st.velocity) > 0.25) {
      const dir = st.dragDist > 0 ? 1 : -1;
      let steps = 1;
      if (Math.abs(st.velocity) > 0.7) steps = 2;
      if (Math.abs(st.velocity) > 1.3) steps = 3;
      snapTo(st.lastIndex + dir * steps);
    }
    st.dragDist = 0;
    st.lastTickDist = 0;
  }, [snapTo, isMobile]);

  useEffect(() => {
    const mm = (e) => onDM(e.clientX);
    const mu = () => onDE();
    const tm = (e) => onDM(e.touches[0].clientX);
    const tu = () => onDE();
    window.addEventListener("mousemove", mm);
    window.addEventListener("mouseup", mu);
    window.addEventListener("touchmove", tm, { passive: true });
    window.addEventListener("touchend", tu);
    return () => {
      window.removeEventListener("mousemove", mm);
      window.removeEventListener("mouseup", mu);
      window.removeEventListener("touchmove", tm);
      window.removeEventListener("touchend", tu);
    };
  }, [onDM, onDE]);

  useEffect(() => {
    const onKey = (e) => {
      if (!containerRef.current) return;
      const r = containerRef.current.getBoundingClientRect();
      if (r.top > window.innerHeight || r.bottom < 0) return;
      if (e.key === "ArrowRight") {
        e.preventDefault();
        snapTo(s.current.lastIndex + 1);
      }
      if (e.key === "ArrowLeft") {
        e.preventDefault();
        snapTo(s.current.lastIndex - 1);
      }
    };
    window.addEventListener("keydown", onKey);
    return () => window.removeEventListener("keydown", onKey);
  }, [snapTo]);

  const handleSelect = useCallback(
    (idx) => {
      if (idx === activeIndex) onMemberClick(members[idx]);
      else snapTo(idx);
    },
    [activeIndex, members, onMemberClick, snapTo]
  );

  const ch = isMobile ? 260 : 340;

  return (
    <section className="mb-10 md:mb-16">
      {/* Header */}
      <div className="mx-auto max-w-6xl px-4 mb-3 md:mb-6">
        <div className="flex items-center gap-2.5 md:gap-3.5">
          <span className="text-xl md:text-2xl">{department.icon}</span>
          <h2 className="text-lg font-bold text-white md:text-2xl">
            {department.name}
          </h2>
          <div className="h-px flex-1 bg-white/[0.06]" />
          <span className="rounded-full bg-white/[0.04] px-2.5 py-0.5 font-mono text-[10px] text-white/30">
            {members.length}
          </span>
        </div>
        <p className="mt-1 ml-8 md:ml-10 text-[10px] md:text-xs text-white/15">
          {isMobile
            ? "Swipe to browse · Tap to view"
            : "Drag to browse · Click to view"}
        </p>
      </div>

      {/* Carousel area */}
      <div
        ref={containerRef}
        className="relative mx-auto w-full max-w-4xl overflow-hidden select-none"
        style={{
          perspective: isMobile ? "800px" : "1100px",
          height: ch,
          cursor: "grab",
          touchAction: "pan-y",
          overscrollBehaviorX: "none",
        }}
        onMouseDown={(e) => {
          e.preventDefault();
          onDS(e.clientX);
        }}
        onTouchStart={(e) => onDS(e.touches[0].clientX)}
      >
        {/* Edge fades */}
        <div className="absolute left-0 top-0 bottom-0 w-12 md:w-20 bg-gradient-to-r from-[#0a0a1a] to-transparent z-20 pointer-events-none" />
        <div className="absolute right-0 top-0 bottom-0 w-12 md:w-20 bg-gradient-to-l from-[#0a0a1a] to-transparent z-20 pointer-events-none" />

        {/* 3D card track */}
        <div
          className="relative h-full w-full"
          style={{ transformStyle: "preserve-3d" }}
        >
          {members.map((m, i) => (
            <MemberCard
              key={m.id}
              member={m}
              index={i}
              activeIndex={activeIndex}
              totalCards={members.length}
              onSelect={handleSelect}
              isMobile={isMobile}
            />
          ))}
        </div>

        {/* Desktop nav arrows */}
        {!isMobile && activeIndex > 0 && (
          <button
            onClick={() => snapTo(activeIndex - 1)}
            className="absolute left-5 top-1/2 z-30 -translate-y-1/2 flex h-9 w-9 items-center justify-center rounded-full border border-white/[0.08] bg-white/[0.03] text-white/30 hover:bg-white/10 hover:text-white"
            aria-label="Previous"
          >
            <svg
              className="h-3.5 w-3.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                strokeLinecap="round"
                strokeLinejoin="round"
                strokeWidth={2}
                d="M15 19l-7-7 7-7"
              />
            </svg>
          </button>
        )}
        {!isMobile && activeIndex < members.length - 1 && (
          <button
            onClick={() => snapTo(activeIndex + 1)}
            className="absolute right-5 top-1/2 z-30 -translate-y-1/2 flex h-9 w-9 items-center justify-center rounded-full border border-white/[0.08] bg-white/[0.03] text-white/30 hover:bg-white/10 hover:text-white"
            aria-label="Next"
          >
            <svg
              className="h-3.5 w-3.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                strokeLinecap="round"
                strokeLinejoin="round"
                strokeWidth={2}
                d="M9 5l7 7-7 7"
              />
            </svg>
          </button>
        )}
      </div>

      {/* Dots */}
      <div className="mt-2.5 md:mt-4 flex items-center justify-center gap-1">
        {members.map((_, i) => (
          <button
            key={i}
            onClick={() => snapTo(i)}
            className={`rounded-full transition-all duration-300 ${i === activeIndex
              ? "h-1.5 w-6 bg-white/40"
              : "h-1.5 w-1.5 bg-white/10 hover:bg-white/25"
              }`}
            style={{ minWidth: 6, minHeight: 6 }}
            aria-label={`View ${members[i].name}`}
          />
        ))}
      </div>
    </section>
  );
}

// ═══════════════════════════════════════════
// SOUND TOGGLE
// ═══════════════════════════════════════════

function SoundToggle({ isMuted, onToggle }) {
  return (
    <button
      onClick={onToggle}
      className="fixed bottom-5 right-5 z-[70] flex h-11 w-11 items-center justify-center rounded-full border border-white/[0.08] bg-[#0f0f25]/80 text-white/40 backdrop-blur-lg hover:bg-white/10 hover:text-white active:scale-95 shadow-lg shadow-black/20"
      aria-label={isMuted ? "Unmute" : "Mute"}
      title={isMuted ? "Unmute" : "Mute"}
    >
      {isMuted ? <FaVolumeXmark size={16} /> : <FaVolumeHigh size={16} />}
    </button>
  );
}

// ═══════════════════════════════════════════
// GLOBAL STYLES (injected once)
// ═══════════════════════════════════════════

function GlobalStyles() {
  return (
    <style>{`
      @keyframes spin-slow {
        from {
          transform: rotate(0deg);
        }
        to {
          transform: rotate(360deg);
        }
      }
      @keyframes spin-reverse {
        from {
          transform: translate(-50%, -50%) rotate(0deg);
        }
        to {
          transform: translate(-50%, -50%) rotate(-360deg);
        }
      }
      @keyframes fadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }
      @keyframes modalSlideUp {
        from {
          opacity: 0;
          transform: scale(0.92) translateY(40px);
        }
        to {
          opacity: 1;
          transform: scale(1) translateY(0);
        }
      }
      @keyframes contentEntry {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .content-enter {
        animation: contentEntry 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        animation-delay: 0.1s;
        opacity: 0;
      }
      ::selection {
        background: rgba(139, 92, 246, 0.3);
        color: white;
      }
      html {
        scroll-behavior: smooth;
      }
      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }
    `}</style>
  );
}

// ═══════════════════════════════════════════
// MAIN PAGE EXPORT
// ═══════════════════════════════════════════

export default function TeamPage() {
  const [loading, setLoading] = useState(false);
  const [modalMember, setModalMember] = useState(null);
  const [modalOpen, setModalOpen] = useState(false);
  const particleRef = useRef(null);
  const { playGearClick, playEngraveThud, isMuted, toggleMute } =
    useSoundEngine();

  // Preload all team photos while loader is showing
  useEffect(() => {
    const photos = departments.flatMap((d) => d.members.map((m) => m.photo));
    [...new Set(photos)].forEach((src) => {
      const img = new window.Image();
      img.src = src;
    });
  }, []);

  const onLoaderDone = useCallback(() => setLoading(false), []);

  const openModal = useCallback((m) => {
    setModalMember(m);
    setModalOpen(true);
  }, []);

  const closeModal = useCallback(() => {
    setModalOpen(false);
    setTimeout(() => setModalMember(null), 300);
  }, []);

  return (
    <main className="min-h-screen bg-[#0a0a1a]">
      <GlobalStyles />

      {/* {loading && <TeamLoader onComplete={onLoaderDone} />} */}

      <ParticleCanvas ref={particleRef} />

      <SoundToggle isMuted={isMuted} onToggle={toggleMute} />

      <div className="content-enter">
        <TeamHero />

        <div className="py-2 md:py-6">
          {departments.map((dept) => (
            <DepartmentCarousel
              key={dept.id}
              department={dept}
              onMemberClick={openModal}
              playGearClick={playGearClick}
              playEngraveThud={playEngraveThud}
              particleCanvasRef={particleRef}
            />
          ))}
        </div>

        {/* Join CTA */}
        <section className="border-t border-white/[0.04] py-14 md:py-20">
          <div className="mx-auto max-w-2xl px-5 text-center">
            <h2 className="text-2xl font-bold text-white md:text-3xl">
              Think You Belong Here?
            </h2>
            <p className="mx-auto mt-3 max-w-md text-sm text-white/25">
              We recruit the best every semester. Show us what you&apos;ve got.
            </p>
            <a
              href="/join"
              className="mt-6 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/[0.04] px-6 py-2.5 text-sm font-semibold text-white hover:bg-white/[0.08] hover:border-white/25 active:scale-95"
            >
              Apply Now
              <svg
                className="h-3.5 w-3.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  strokeLinecap="round"
                  strokeLinejoin="round"
                  strokeWidth={2.5}
                  d="M13 7l5 5m0 0l-5 5m5-5H6"
                />
              </svg>
            </a>
          </div>
        </section>
      </div>

      <MemberModal
        member={modalMember}
        isOpen={modalOpen}
        onClose={closeModal}
      />
    </main>
  );
}