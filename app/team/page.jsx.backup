// ═══════════════════════════════════════════
// SOUND ENGINE HOOK
// ═══════════════════════════════════════════

function useSoundEngine() {
  const [isMuted, setIsMuted] = useState(false);
  const isMutedRef = useRef(false);
  const ctxRef = useRef(null);
  const gearBuf = useRef(null);
  const thudBuf = useRef(null);

  useEffect(() => {
    isMutedRef.current = isMuted;
  }, [isMuted]);

  useEffect(() => {
    let ctx = null;
    try {
      const AC = window.AudioContext || window.webkitAudioContext;
      if (!AC) return;
      ctx = new AC();
      ctxRef.current = ctx;

      const load = async (url) => {
        try {
          const r = await fetch(url);
          if (!r.ok) return null;
          const ab = await r.arrayBuffer();
          return await ctx.decodeAudioData(ab);
        } catch {
          return null;
        }
      };

      // ▼▼▼ YOUR SOUND FILES ▼▼▼
      Promise.all([
        load("/sounds/freesound_community-running-gear-6403.mp3"),
        load("/sounds/mixkit-short-rising-thud-3133.wav"),
      ]).then(([g, t]) => {
        gearBuf.current = g;
        thudBuf.current = t;
      });
    } catch { }

    return () => {
      if (ctx && ctx.state !== "closed") ctx.close().catch(() => { });
    };
  }, []);

  useEffect(() => {
    const resume = () => {
      if (ctxRef.current && ctxRef.current.state === "suspended")
        ctxRef.current.resume().catch(() => { });
    };
    document.addEventListener("click", resume);
    document.addEventListener("touchstart", resume);
    return () => {
      document.removeEventListener("click", resume);
      document.removeEventListener("touchstart", resume);
    };
  }, []);

  const play = useCallback((buffer, vol, offset, dur) => {
    if (isMutedRef.current || !buffer || !ctxRef.current) return;
    const ctx = ctxRef.current;
    if (ctx.state === "suspended") {
      ctx.resume().catch(() => { });
      return;
    }
    try {
      const src = ctx.createBufferSource();
      src.buffer = buffer;
      const gain = ctx.createGain();
      gain.gain.value = vol;
      src.connect(gain);
      gain.connect(ctx.destination);
      if (dur && dur > 0) src.start(0, offset || 0, dur);
      else src.start(0, offset || 0);
    } catch { }
  }, []);

  const playGearClick = useCallback(() => {
    const b = gearBuf.current;
    if (!b) return;
    // Play a tiny 0.08s slice from a random position in the gear sound
    const ms = Math.max(0, b.duration - 0.15);
    play(b, 0.25, Math.random() * ms, 0.08);
  }, [play]);

  const playEngraveThud = useCallback(() => {
    const b = thudBuf.current;
    if (!b) return;
    play(b, 0.55, 0, null);
  }, [play]);

  const toggleMute = useCallback(() => setIsMuted((p) => !p), []);

  return { playGearClick, playEngraveThud, isMuted, toggleMute };
}

// ═══════════════════════════════════════════
// PARTICLE CANVAS
// ═══════════════════════════════════════════

const ParticleCanvas = forwardRef(function ParticleCanvas(_, ref) {
  const canvasRef = useRef(null);
  const particles = useRef([]);
  const raf = useRef(null);
  const running = useRef(false);

  const mkP = (x, y) => {
    const a = Math.random() * Math.PI * 2;
    const sp = Math.random() * 5 + 2;
    const br = Math.random() * 80 + 175;
    const gold = Math.random() > 0.75;
    return {
      x,
      y,
      size: Math.random() * 2.5 + 0.8,
      vx: Math.cos(a) * sp,
      vy: Math.sin(a) * sp,
      grav: 0.06,
      fric: 0.97,
      life: 1,
      decay: Math.random() * 0.018 + 0.006,
      r: gold ? 220 : br,
      g: gold ? 200 : br,
      b: gold ? 170 : br + 10,
      alpha: Math.random() * 0.6 + 0.3,
    };
  };

  const render = useCallback(() => {
    const cv = canvasRef.current;
    if (!cv) return;
    const ctx = cv.getContext("2d");
    if (!ctx) return;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    ctx.clearRect(0, 0, cv.width, cv.height);

    const alive = [];
    for (const p of particles.current) {
      p.vx *= p.fric;
      p.vy *= p.fric;
      p.vy += p.grav;
      p.x += p.vx;
      p.y += p.vy;
      p.life -= p.decay;
      if (p.life <= 0) continue;
      alive.push(p);
      ctx.globalAlpha = p.life * p.alpha;
      ctx.fillStyle = `rgb(${p.r},${p.g},${p.b})`;
      ctx.beginPath();
      ctx.arc(p.x * dpr, p.y * dpr, p.size * p.life * dpr, 0, Math.PI * 2);
      ctx.fill();
    }
    particles.current = alive;

    if (alive.length > 0) {
      raf.current = requestAnimationFrame(render);
    } else {
      running.current = false;
      ctx.clearRect(0, 0, cv.width, cv.height);
    }
  }, []);

  const burst = useCallback(
    (x, y) => {
      const n = 35 + Math.floor(Math.random() * 15);
      for (let i = 0; i < n; i++) particles.current.push(mkP(x, y));
      if (!running.current) {
        running.current = true;
        raf.current = requestAnimationFrame(render);
      }
    },
    [render]
  );

  useImperativeHandle(ref, () => ({ burst }), [burst]);

  useEffect(() => {
    const cv = canvasRef.current;
    if (!cv) return;
    const resize = () => {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      cv.width = window.innerWidth * dpr;
      cv.height = window.innerHeight * dpr;
      cv.style.width = window.innerWidth + "px";
      cv.style.height = window.innerHeight + "px";
    };
    resize();
    window.addEventListener("resize", resize);
    return () => {
      window.removeEventListener("resize", resize);
      if (raf.current) cancelAnimationFrame(raf.current);
    };
  }, []);

  return (
    <canvas
      ref={canvasRef}
      className="pointer-events-none fixed inset-0 z-[60]"
    />
  );
});

// ═══════════════════════════════════════════
// LOADER
// ═══════════════════════════════════════════

function TeamLoader({ onComplete }) {
  const [progress, setProgress] = useState(0);
  const [phase, setPhase] = useState("loading");

  useEffect(() => {
    let rafId = null;
    let start = null;
    const dur = 2200;
    const tick = (ts) => {
      if (!start) start = ts;
      const raw = Math.min(100, ((ts - start) / dur) * 100);
      setProgress(100 * (1 - Math.pow(1 - raw / 100, 3)));
      if (raw < 100) rafId = requestAnimationFrame(tick);
    };
    rafId = requestAnimationFrame(tick);
    return () => {
      if (rafId) cancelAnimationFrame(rafId);
    };
  }, []);

  useEffect(() => {
    if (progress >= 99.5 && phase === "loading") {
      setProgress(100);
      setPhase("exiting");
      const t = setTimeout(() => {
        setPhase("done");
        onComplete();
      }, 700);
      return () => clearTimeout(t);
    }
  }, [progress, phase, onComplete]);

  if (phase === "done") return null;

  return (
    <div
      className={`fixed inset-0 z-[200] flex flex-col items-center justify-center bg-[#0a0a1a] transition-all duration-700 ${phase === "exiting" ? "opacity-0 scale-105" : ""
        }`}
    >
      <div className="absolute inset-0 bg-[radial-gradient(circle_at_center,_rgba(30,20,60,0.4)_0%,_transparent_70%)]" />

      {/* Gears */}
      <div className="relative mb-10">
        <svg
          className="h-20 w-20 text-white/[0.07]"
          viewBox="0 0 100 100"
          fill="currentColor"
          style={{ animation: "spin-slow 4s linear infinite" }}
        >
          <path d="M44 2h12v14h-12zM44 84h12v14h-12zM2 44h14v12H2zM84 44h14v12H84zM17.2 12.4l8.5 8.5-8.5 8.5-8.5-8.5zM74.3 69.6l8.5 8.5-8.5 8.5-8.5-8.5zM12.4 82.8l8.5-8.5 8.5 8.5-8.5 8.5zM69.6 25.7l8.5-8.5 8.5 8.5-8.5 8.5z" />
          <circle cx="50" cy="50" r="25" opacity="0.5" />
        </svg>
        <svg
          className="absolute left-1/2 top-1/2 h-10 w-10 text-white/[0.12]"
          viewBox="0 0 50 50"
          fill="currentColor"
          style={{
            animation: "spin-reverse 3s linear infinite",
            transform: "translate(-50%,-50%)",
          }}
        >
          <circle cx="25" cy="25" r="6" />
          <rect x="23" y="2" width="4" height="8" rx="2" />
          <rect x="23" y="40" width="4" height="8" rx="2" />
          <rect x="2" y="23" width="8" height="4" rx="2" />
          <rect x="40" y="23" width="8" height="4" rx="2" />
        </svg>
        <div className="absolute left-1/2 top-1/2 h-2 w-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white/30" />
      </div>

      <div className="relative z-10 text-center">
        <p className="font-mono text-[11px] uppercase tracking-[0.3em] text-white/25">
          {progress < 100 ? "Assembling Roster" : "Ready"}
        </p>
        <div className="mx-auto mt-5 h-[2px] w-44 overflow-hidden rounded-full bg-white/[0.06]">
          <div
            className="h-full rounded-full bg-gradient-to-r from-white/10 via-white/40 to-white/10"
            style={{ width: `${progress}%`, transition: "width 0.1s linear" }}
          />
        </div>
        <p className="mt-2.5 font-mono text-[10px] tabular-nums text-white/15">
          {Math.floor(progress)}%
        </p>
      </div>
    </div>
  );
}

